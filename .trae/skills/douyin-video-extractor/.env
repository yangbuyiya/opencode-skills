# 抖音视频提取器配置文件
# 请根据实际情况修改以下配置项

# ==================== API 配置 ====================
# 硅基流动 API 密钥（必需）
# 获取方式：访问 https://cloud.siliconflow.cn/ 注册并获取 API Key
DOUYIN_API_KEY=your-api-key-here

# API 基础 URL（可选，默认使用硅基流动）
API_BASE_URL=https://api.siliconflow.cn/v1/audio/transcriptions

# 语音识别模型（可选，默认为 SenseVoiceSmall）
TRANSCRIPTION_MODEL=FunAudioLLM/SenseVoiceSmall

# ==================== 输出配置 ====================
# 输出目录（相对于当前脚本所在目录）
OUTPUT_DIR=../output

# 是否保留视频文件（true/false）
SAVE_VIDEO=false

# 是否保留音频文件（true/false）
SAVE_AUDIO=false

# ==================== 请求配置 ====================
# 请求超时时间（秒）
REQUEST_TIMEOUT=60

# 下载超时时间（秒）
DOWNLOAD_TIMEOUT=60

# ==================== 其他配置 ====================
# 是否显示进度信息（true/false）
SHOW_PROGRESS=true

# 用户代理（可选）
USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_2 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) EdgiOS/121.0.2277.107 Version/17.0 Mobile/15E148 Safari/604.1
